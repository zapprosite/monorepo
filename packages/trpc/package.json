{
	"name": "@repo/trpc",
	"version": "1.0.0",
	"description": "tRPC routers and client for the monorepo",
	"type": "module",
	"sideEffects": false,
	"license": "AGPL-3.0-only",
	"private": true,
	"scripts": {
		"check-types": "tsc --noEmit",
		"build": "tsc && tsc-alias",
		"dev": "concurrently --kill-others \"tsc -w\" \"tsc-alias -w\"",
		"clean": "rm -rf node_modules && rm -rf dist",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@trpc/server": "^10.45.0",
		"@trpc/client": "^10.45.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/node": "^20.11.0"
	},
	"exports": {
		"./*": {
			"types": "./src/*.ts",
			"import": "./dist/*.js",
			"default": "./dist/*.js"
		}
	}
}
