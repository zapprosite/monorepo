{
	"name": "@repo/email",
	"version": "1.0.0",
	"description": "React Email templates for the monorepo",
	"type": "module",
	"sideEffects": false,
	"license": "AGPL-3.0-only",
	"private": true,
	"scripts": {
		"check-types": "tsc --noEmit",
		"build": "tsc && tsc-alias",
		"dev": "concurrently --kill-others \"tsc -w\" \"tsc-alias -w\"",
		"clean": "rm -rf node_modules && rm -rf dist",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"preview": "email dev"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"@react-email/render": "^2.0.8",
		"react-email": "^6.0.5"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/react": "^19.2.2",
		"tsc-alias": "^1.8.16",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"resend": "^4.1.2"
	},
	"exports": {
		"./*": {
			"types": "./src/*.ts",
			"import": "./dist/*.js",
			"default": "./dist/*.js"
		},
		"./templates/*": {
			"types": "./src/templates/*.tsx",
			"import": "./dist/templates/*.js",
			"default": "./dist/templates/*.js"
		}
	}
}
