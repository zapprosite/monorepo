#!/bin/bash
# Smart STT Selector — shell wrapper
# SPEC-055-v2: VRAM-aware STT provider selection
# Usage: source stt-selector.sh && echo $STT_PROVIDER

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load .env if present
if [ -f "$SCRIPT_DIR/../.env" ]; then
  set -a
  source "$SCRIPT_DIR/../.env"
  set +a
fi

# Run Python selector and export vars
eval "$(python3 "$SCRIPT_DIR/smart-stt-selector.py")"

# Export for subshells
export STT_PROVIDER STT_URL VRAM_FREE_GB
