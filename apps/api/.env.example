# Node Environment
NODE_ENV=development

# Server Port - usar 4002+ para dev local (4000/4001 reservados)
PORT=4002

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=connected_repo_db

WEBAPP_URL=http://localhost:5173
VITE_API_URL=http://localhost:4002

# Allowed Origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google OAuth Credentials
# Em dev local, OAuth não funciona sem domain real
# Use X-Dev-User header para bypass de auth (veja dev-auth-bypass.ts)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session Secret (minimum 32 characters - generate with: openssl rand -base64 32)
SESSION_SECRET=dev-only-secret-key-min-32-chars-for-local-dev

# Internal API Secret (minimum 32 characters - used for internal endpoints like webhook processor)
INTERNAL_API_SECRET=dev-internal-secret-key-min-32-chars-for-local-testing