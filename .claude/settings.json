{
  "permissions": {
    "allow": [
      "Bash(go vet ./...)",
      "Bash(go build ./cmd/...)",
      "Bash(go test -v -race ./...)",
      "Bash(go test -cover ./...)",
      "Bash(go tool cover*)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "agentsDir": ".claude/agents",
  "skillsDir": ".claude/skills",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-spec-exists.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-go-checks.sh"
          }
        ]
      }
    ]
  }
}
