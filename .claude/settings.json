{
  "permissions": {
    "allow": [
      { "command": "go", "args": ["vet", "./..."] },
      { "command": "go", "args": ["build", "./cmd/..."] },
      { "command": "go", "args": ["test", "-v", "-race", "./..."] },
      { "command": "go", "args": ["test", "-cover", "./..."] },
      { "command": "go", "args": ["tool", "cover"] }
    ]
  },
  "agentsDir": ".claude/agents",
  "skillsDir": ".claude/skills",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-spec-exists.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-go-checks.sh"
          }
        ]
      }
    ]
  }
}
