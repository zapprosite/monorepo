{
  "$schema": "./qdrant-hybrid-search.schema.json",
  "collection": "will",
  "description": "Qdrant hybrid search configuration combining dense vectors (semantic) + sparse vectors (BM25) for Brain Refactor",
  "version": "1.0.0",
  "updated_at": "2026-04-24",
  "strategy": "hybrid",
  "components": {
    "dense_vectors": {
      "enabled": true,
      "config": {
        "vector_size": 768,
        "distance": "Cosine",
        "hnsw_config": {
          "m": 16,
          "ef_construct": 200,
          "full_scan_threshold": 10000
        }
      },
      "model": "nomic-embed-text"
    },
    "sparse_vectors": {
      "enabled": true,
      "config": {
        "algorithm": "BM25",
        "bm25_parameters": {
          "k1": 1.5,
          "b": 0.75,
          "on": "TEXT"
        }
      },
      "description": "Sparse vectors for keyword/BM25 matching"
    }
  },
  "search_modes": {
    "hybrid": {
      "fusion_algorithm": "RRF",
      "rrf_k": 100,
      "alpha": 0.5,
      "description": "Reciprocal Rank Fusion combining dense + sparse scores"
    },
    "semantic_only": {
      "description": "Pure vector similarity (semantic search)"
    },
    "keyword_only": {
      "description": "Pure BM25 keyword matching"
    }
  },
  "reranking": {
    "enabled": false,
    "rerankers": [
      {
        "name": "colbert",
        "description": "Late interaction reranker (future)"
      }
    ]
  },
  "query_examples": {
    "hybrid_basic": {
      "query_text": "how does the agent loop work",
      "mode": "hybrid",
      "params": {
        "limit": 10,
        "score_threshold": 0.5
      },
      "expected": "Combines semantic + BM25 for best results"
    },
    "hybrid_with_filter": {
      "query_text": "hermes gateway config",
      "mode": "hybrid",
      "filter": {
        "doc_type": "service",
        "service_name": "hermes-gateway"
      },
      "params": {
        "limit": 5
      }
    },
    "keyword_boosted": {
      "query_text": "ADR 001 architecture decisions",
      "mode": "hybrid",
      "params": {
        "alpha": 0.3,
        "limit": 10
      },
      "note": "Lower alpha = more weight on BM25 keyword match"
    },
    "semantic_boosted": {
      "query_text": "conversational memory patterns",
      "mode": "hybrid",
      "params": {
        "alpha": 0.8,
        "limit": 10
      },
      "note": "Higher alpha = more weight on semantic similarity"
    }
  },
  "requirements": {
    "qdrant_version": ">=1.7.0",
    "note": "Hybrid search with sparse vectors requires Qdrant 1.7+"
  }
}
