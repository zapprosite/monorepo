{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/nest:build",
      "options": {
        "outputPath": "dist/apps/api"
      }
    },
    "serve": {
      "executor": "@nx/nest:serve",
      "options": {
        "port": 4000
      }
    },
    "test": {
      "executor": "@nx/jest:jest"
    }
  }
}
