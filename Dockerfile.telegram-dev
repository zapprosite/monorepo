FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY . .
RUN go build -o telegram-dev ./cmd/telegram-dev

FROM alpine:latest

WORKDIR /app
COPY --from=builder /app/telegram-dev .
COPY --from=builder /app/.env .env

CMD ["./telegram-dev", "-token", "${TELEGRAM_BOT_TOKEN}", "-redis", "${REDIS_ADDR:-localhost:6379}", "-redis-pass", "${REDIS_PASSWORD}"]