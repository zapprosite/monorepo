{
  "models": {
    "main": {
      "provider": "anthropic",
      "modelId": "claude-sonnet-4-5",
      "maxTokens": 64000,
      "temperature": 0.2
    },
    "research": {
      "provider": "anthropic",
      "modelId": "claude-opus-4-5",
      "maxTokens": 32000,
      "temperature": 0.1
    },
    "fallback": {
      "provider": "openai-compatible",
      "baseURL": "${ANTHROPIC_BASE_URL}",
      "modelId": "${ANTHROPIC_MODEL}",
      "maxTokens": 32000,
      "temperature": 0.2
    }
  },
  "global": {
    "logLevel": "info",
    "debug": false,
    "defaultSubtasks": 5,
    "defaultPriority": "medium",
    "projectName": "zappro-monorepo",
    "tasksFilePath": "tasks/pipeline.json"
  }
}
