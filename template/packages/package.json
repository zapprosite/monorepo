{
  "name": "@repo/package-template",
  "version": "0.0.1",
  "private": true,
  "description": "Package template for monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ."
  },
  "dependencies": {
    "zod": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0",
    "biome": "^2.0.0"
  }
}
