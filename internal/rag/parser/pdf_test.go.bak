// ----------------------------------------------------------------
// Integration-style tests (require PDF tools)
// ----------------------------------------------------------------

func TestPDFParser_WithPdftotextAvailable(t *testing.T) {
	// Skip if pdftotext not available - this is an environment-dependent test
	// Run with: go test -v -run TestPDFParser_WithPdftotext ./internal/rag/parser/

	parser := NewPDFParser()

	// Create a real-ish PDF for testing
	pdfContent := `%PDF-1.4
1 0 obj << /Type /Catalog /Pages 2 0 R >> endobj
2 0 obj << /Type /Pages /Kids [3 0 R] /Count 1 >> endobj
3 0 obj << /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] >> endobj
xref
0 4
0000000000 65535 f
0000000009 00000 n
0000000058 00000 n
0000000115 00000 n
trailer << /Root 1 0 R /Size 4 >>
startxref
196
%%EOF`

	filePath := minimalPDF(t, "integration.pdf", pdfContent)

	// Try to extract - will work only if pdftotext is installed
	_, err := parser.ExtractAllText(filePath)

	// This test passes if either:
	// 1. Tools are available and extraction succeeds
	// 2. Tools not available and we get appropriate error
	if err != nil && !contains(err.Error(), "no PDF text extraction tool available") {
		t.Logf("Note: pdftotext may not be installed. Error: %v", err)
	}
}

func contains(s, substr string) bool {
	return len(s) >= len(substr) && (s == substr || len(s) > 0 && containsAt(s, substr, 0))
}

func containsAt(s, substr string, start int) bool {
	for i := start; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}
