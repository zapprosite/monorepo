model_list:
  - model_name: deepseek-v4-flash
    litellm_params:
      model: openrouter/deepseek/deepseek-v4-flash
      api_key: os.environ/OPENROUTER_API_KEY
  - model_name: qwen2.5-coder:14b-q6k
    litellm_params:
      model: ollama/qwen2.5-coder:14b-q6k
      api_base: os.environ/OLLAMA_URL
      api_key: dummy
  - model_name: qwen2.5vl:3b
    litellm_params:
      model: ollama/qwen2.5vl:3b
      api_base: os.environ/OLLAMA_URL
      api_key: dummy
  - model_name: embedding-nomic
    litellm_params:
      model: ollama/nomic-embed-text
      api_base: os.environ/OLLAMA_URL
      api_key: dummy
  - model_name: zappro-clima-tutor
    litellm_params:
      model: openrouter/deepseek/deepseek-v4-flash
      api_key: os.environ/OPENROUTER_API_KEY

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY

litellm_settings:
  drop_params: true
  set_verbose: false
