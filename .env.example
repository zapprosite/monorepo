# =============================================================================
# homelab-monorepo — Environment Variables Template
# =============================================================================
# THIS FILE IS THE CANONICAL SOURCE FOR ALL ENV VAR DOCUMENTATION.
# Values are placeholders only. Never commit real secrets here.
#
# Rule: Code reads from .env, never hardcodes secrets.
# See: docs/GUIDES/env-management.md
# =============================================================================

# ==========================================
# Core & System
# ==========================================
NODE_ENV=development
DISPLAY=:1
GOGC=100
GOMEMLIMIT=512MiB
PORTEIRO_MODE=LOG_ONLY
API_BASE_URL=http://localhost:4001/trpc

# Generated secrets (Minimum 32 characters. Generate with: openssl rand -base64 32)
SESSION_SECRET=replace-with-openssl-rand-base64-32
INTERNAL_API_SECRET=replace-with-openssl-rand-base64-32

# Feature Flags
FEAT_COMPUTER_USE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_VOICE=false
HOOKS_ENABLED=false
HOOKS_PATH=/hooks
BROWSER_EVALUATE_ENABLED=true

# ==========================================
# AI Models, LLMs & Gateways (SPEC-047)
# ==========================================
# Keys
OPEN_AI_KEY=sk-proj-replace-with-your-openai-key
GROQ_API_KEY=gsk_replace-with-your-groq-key
OPENROUTER_API_KEY=sk-or-v1-replace-with-your-openrouter-key
OPENCODE_API_KEY=sk-replace-with-your-opencode-key
MINIMAX_GROUP_ID=your-minimax-group-id
MINIMAX_API_KEY=replace-with-your-minimax-key
HF_TOKEN=hf_replace-with-your-huggingface-token

# Context7
CONTEXT7_ENABLED=true
CONTEXT7_API_KEY=ctx7sk-replace-with-your-context7-key

# AI Gateway (Facade)
AI_GATEWAY_PORT=4002
# Generate with: openssl rand -hex 32
AI_GATEWAY_FACADE_KEY=replace-with-openssl-rand-hex-32
PTBR_FILTER_MODEL=Gemma4-12b-it

# LiteLLM
LITELLM_URL=https://llm.zappro.site/v1
LITELLM_LOCAL_URL=http://localhost:4000/v1
LITELLM_UI_URL=http://localhost:4000/ui
LITELLM_MASTER_KEY=sk-replace-with-your-litellm-master-key

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=Gemma4-12b-it
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# ==========================================
# Hermes Agent & Voice Pipeline
# ==========================================
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_API_KEY=replace-with-openssl-rand-hex-32

# Voice Pipeline URLs
TTS_BRIDGE_URL=http://localhost:8013
KOKORO_URL=http://localhost:8880
STT_DIRECT_URL=http://localhost:8204
WHISPER_MEDIUM_PORT=8204
DEEPGRAM_API_KEY=replace-with-your-deepgram-api-key

# Hermes Agency (CEO_REFRIMIX_bot @CEO_REFRIMIX_bot — Agent Lider)
HERMES_AGENCY_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Bots adicionais
EDITOR_SOCIAL_BOT_TOKEN=  # @editor_social_bot
ATHLOS_BOT_TOKEN=         # @Athlos_Life_bot
HOMELAB_LOGS_BOT_TOKEN=   # @HOMELAB_LOGS_bot

# Hermes Agency Datacenter Hardening (SPEC-059)
HERMES_ADMIN_USER_IDS=  # CSV of Telegram user IDs that can see internal ports in /health
HERMES_MAX_FILE_SIZE=20971520  # 20MB in bytes
HERMES_MAX_CONCURRENT=3  # max concurrent uploads per user
HERMES_LOCK_TTL_SEC=30  # distributed lock TTL in seconds
HERMES_RATE_WINDOW_MS=10000  # rate limit window in milliseconds
HERMES_RATE_MAX_MSGS=5  # max messages per rate limit window
HERMES_CLEANUP_INTERVAL_MS=60000  # memory cleanup interval in milliseconds
HERMES_CIRCUIT_BREAKER_THRESHOLD=5  # failures before circuit breaker opens
HERMES_CIRCUIT_BREAKER_COOLDOWN_MS=30000  # circuit breaker cooldown in milliseconds
HERMES_MAX_TTS_SIZE_BYTES=52428800  # 50MB max TTS response size
HERMES_MAX_DOWNLOAD_BYTES=20971520  # 20MB max Telegram file download (streaming limit)

# ==========================================
# Databases & Storage
# ==========================================
POSTGRES_PASSWORD=your-postgres-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
QDRANT_API_KEY=your-qdrant-api-key

# API Database (OrchidORM / connected_repo_db)
# Container: zappro-litellm-db (Docker network)
DB_HOST=zappro-litellm-db
DB_PORT=5432
DB_NAME=connected_repo_db
DB_USER=litellm
DB_PASSWORD=replace-with-openssl-rand-hex-16

# ==========================================
# Coolify Infrastructure
# ==========================================
COOLIFY_URL=https://coolify.zappro.site
COOLIFY_API_KEY=your-coolify-api-key
COOLIFY_APP_KEY=base64:your-coolify-app-key
COOLIFY_ROOT_USER_PASSWORD=your-coolify-root-password
COOLIFY_DB_PASSWORD=your-coolify-db-password
COOLIFY_REDIS_PASSWORD=your-coolify-redis-password

# ==========================================
# Cloudflare
# ==========================================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
cloudflare_tunnel_name=will-zappro-homelab
cloudflare_tunnel_id=your-tunnel-id
cloudflare_tunnel_cname=your-tunnel-id.cfargotunnel.com
cloudflare_tunnel_secret=your-tunnel-secret

# ==========================================
# Observability (Grafana)
# ==========================================
GRAFANA_URL=https://grafana.zappro.site
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_your-grafana-service-account-token

# ==========================================
# Git & Repositories (Gitea / GitHub)
# ==========================================
GH_TOKEN=ghp_your-github-token
GITHUB_TOKEN=ghp_your-github-token
GITEA_INSTANCE_URL=https://git.zappro.site
GITEA_TOKEN=your-gitea-token
GITEA_RUNNER_REGISTRATION_TOKEN=your-runner-token

# ==========================================
# Google OAuth
# ==========================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret
GOOGLE_REDIRECT_URI_LIST_WEB=https://list.zappro.site/auth/callback
GOOGLE_REDIRECT_URI_OBSIDIAN=https://obsidian.zappro.site/auth/callback
GOOGLE_REDIRECT_URI_TODO=https://todo.zappro.site/auth/callback

# ==========================================
# N8N Automation
# ==========================================
N8N_URL=https://n8n.zappro.site
N8N_WEBHOOK_URL=https://n8n.zappro.site/webhook
N8N_DB_PASSWORD=your-n8n-db-password
N8N_API_KEY=your-n8n-api-key
N8N_RUNNERS_AUTH_TOKEN=your-n8n-runners-auth-token

# ==========================================
# Miscellaneous
# ==========================================
SMTP_PASSWORD=your-smtp-password
GF_SECURITY_ADMIN_PASSWORD=your-grafana-security-password
WEBUI_SECRET_KEY=your-webui-secret-key

# ==========================================
# Deprecated / Unused
# ==========================================

# OPENCLAW_DEEPGRAM_API_KEY=  # DEPRECATED - OpenClaw legacy
# OPENCLAW_GATEWAY_TOKEN=  # DEPRECATED - OpenClaw legacy
# OPENCLAW_GEMINI_API_KEY=  # DEPRECATED - OpenClaw legacy
# OPENCLAW_PASSWORD=  # DEPRECATED - OpenClaw legacy
# OPENCLAW_USER=  # DEPRECATED - OpenClaw legacy
# WAV2VEC2_URL=http://localhost:8203  # DEPRECATED - use STT_DIRECT_URL
# STT_PROXY_URL=http://localhost:8203  # DEPRECATED - OpenClaw legacy
# sk-api-... ROTATED 2026-04-16 — insufficient balance
# token_minimax-m2.7_plano=sk-api-... ROTATED

# pgAdmin (Coolify)
PGADMIN_DEFAULT_EMAIL=willianstos@gmail.com
PGADMIN_DEFAULT_PASSWORD=YOUR_PGADMIN_PASSWORD
