# =============================================================================
# homelab-monorepo — Environment Variables Template
# =============================================================================
# THIS FILE IS THE CANONICAL SOURCE FOR ALL ENV VAR DOCUMENTATION.
# Values use ${VAR_NAME} pattern — code reads from environment variables.
# Never hardcode secrets in code; use process.env.VAR_NAME or os.getenv("VAR_NAME").
#
# Rule: Code reads from .env via env vars, never hardcodes secrets.
# See: docs/CLOUDFLARE_SETUP.md, .claude/rules/anti-hardcoded-secrets.md
# =============================================================================

# ==========================================
# Core & System
# ==========================================
NODE_ENV=development
DISPLAY=:1
GOGC=100
GOMEMLIMIT=512MiB
PORTEIRO_MODE=LOG_ONLY
API_BASE_URL=http://localhost:4001/trpc

# Generated secrets — code: os.getenv("SESSION_SECRET")
SESSION_SECRET=${SESSION_SECRET}
INTERNAL_API_SECRET=${INTERNAL_API_SECRET}

# Feature Flags
FEAT_COMPUTER_USE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_VOICE=false
HOOKS_ENABLED=false
HOOKS_PATH=/hooks
BROWSER_EVALUATE_ENABLED=true

# ==========================================
# AI Models, LLMs & Gateways (SPEC-047)
# ==========================================
# Keys — code: process.env.OPEN_AI_KEY
OPEN_AI_KEY=${OPEN_AI_KEY}
GROQ_API_KEY=${GROQ_API_KEY}
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
OPENCODE_API_KEY=${OPENCODE_API_KEY}
HF_TOKEN=${HF_TOKEN}

# MiniMax M2.7 — code: process.env.MINIMAX_API_KEY
# ⚠️ ATENÇÃO: api_base = https://api.minimax.io (NÃO api.minimaxi.com!)
MINIMAX_API_KEY=${MINIMAX_API_KEY}
MINIMAX_API_BASE=https://api.minimax.io
HERMES_MINIMAX_BASE=https://api.minimax.io/anthropic/v1

# Context7 — code: process.env.CONTEXT7_API_KEY
CONTEXT7_ENABLED=true
CONTEXT7_API_KEY=${CONTEXT7_API_KEY}

# AI Gateway (Facade) — code: process.env.AI_GATEWAY_FACADE_KEY
AI_GATEWAY_PORT=4002
AI_GATEWAY_FACADE_KEY=${AI_GATEWAY_FACADE_KEY}
PTBR_FILTER_MODEL=Gemma4-12b-it

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=Gemma4-12b-it
OLLAMA_VISION_MODEL=gemma4

# ==========================================
# Hermes Agent & Voice Pipeline
# ==========================================
HERMES_GATEWAY_URL=http://127.0.0.1:8642
# code: process.env.HERMES_API_KEY
HERMES_API_KEY=${HERMES_API_KEY}
HERMES_WEBHOOK_URL=https://hermes-agency.zappro.site/webhook
HERMES_VISION_MODEL=qwen2.5vl:7b
HERMES_VOICE=pm_santa

# Voice Pipeline URLs
TTS_BRIDGE_URL=http://localhost:8012
KOKORO_URL=http://localhost:8012
STT_DIRECT_URL=http://localhost:8204
WHISPER_MEDIUM_PORT=8204
# code: process.env.DEEPGRAM_API_KEY
DEEPGRAM_API_KEY=${DEEPGRAM_API_KEY}

# Telegram Bots — code: process.env.TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
TELEGRAM_CHAT_ID=7220607041
TELEGRAM_ALLOWED_USERS=7220607041
ATHLOS_BOT_TOKEN=${ATHLOS_BOT_TOKEN}
HOMELAB_LOGS_BOT_TOKEN=${HOMELAB_LOGS_BOT_TOKEN}

# Hermes Agency Datacenter Hardening (SPEC-059)
HERMES_ADMIN_USER_IDS=7220607041
HERMES_MAX_FILE_SIZE=20971520
HERMES_MAX_CONCURRENT=3
HERMES_LOCK_TTL_SEC=30
HERMES_RATE_WINDOW_MS=10000
HERMES_RATE_MAX_MSGS=5
HERMES_CLEANUP_INTERVAL_MS=60000
HERMES_CIRCUIT_BREAKER_THRESHOLD=5
HERMES_CIRCUIT_BREAKER_COOLDOWN_MS=30000
HERMES_MAX_TTS_SIZE_BYTES=52428800
HERMES_MAX_DOWNLOAD_BYTES=20971520

# ==========================================
# Databases & Storage
# ==========================================
# code: process.env.POSTGRES_PASSWORD
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DB_HOST=zappro-litellm-db
DB_PORT=5432
DB_NAME=connected_repo_db
DB_USER=litellm
DB_PASSWORD=${DB_PASSWORD}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# code: process.env.REDIS_PASSWORD
REDIS_PASSWORD=${REDIS_PASSWORD}
# REDIS_URL usa REDIS_PASSWORD — não hardcoded
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_RETRY_DELAY_MS=2000
REDIS_MAX_RETRIES=3

# ==========================================
# Qdrant Vector Database (SPEC-074)
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=localhost:6334
# code: process.env.QDRANT_API_KEY
QDRANT_API_KEY=${QDRANT_API_KEY}
QDRANT_COLLECTION=will
QDRANT_VECTOR_DIM=768
QDRANT_DISTANCE=Cosine

# ==========================================
# LiteLLM Proxy (AI Gateway)
# ==========================================
LITELLM_PORT=4000
LITELLM_HOST=0.0.0.0
LITELLM_URL=http://localhost:4000/v1
LITELLM_LOCAL_URL=http://localhost:4000/v1
LITELLM_PUBLIC_URL=https://llm.zappro.site/v1
LITELLM_UI_URL=http://localhost:4000/ui
# code: process.env.LITELLM_MASTER_KEY
LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}
# code: process.env.LITELLM_API_KEY
LITELLM_API_KEY=${LITELLM_API_KEY}
LITELLM_MODEL_LIST=embedding-nomic,Gemma4-12b-it,qwen2.5vl:3b
LITELLM_EMBEDDING_MODEL=embedding-nomic
LITELLM_EMBEDDING_DIM=768
LITELLM_DROP_params=True

# AI Gateway (ai-gateway service)
STT_PROXY_URL=http://localhost:8204

# ==========================================
# Coolify Infrastructure
# ==========================================
COOLIFY_URL=https://coolify.zappro.site
# code: process.env.COOLIFY_API_KEY
COOLIFY_API_KEY=${COOLIFY_API_KEY}
# code: process.env.COOLIFY_APP_KEY
COOLIFY_APP_KEY=${COOLIFY_APP_KEY}
# code: process.env.COOLIFY_ROOT_USER_PASSWORD
COOLIFY_ROOT_USER_PASSWORD=${COOLIFY_ROOT_USER_PASSWORD}
# code: process.env.COOLIFY_DB_PASSWORD
COOLIFY_DB_PASSWORD=${COOLIFY_DB_PASSWORD}
# code: process.env.COOLIFY_REDIS_PASSWORD
COOLIFY_REDIS_PASSWORD=${COOLIFY_REDIS_PASSWORD}

# ==========================================
# MCP Servers (local - SSE transport)
# ==========================================
MCP_POSTGRES_HOST=localhost
MCP_POSTGRES_PORT=5432
MCP_COOLIFY_URL=http://localhost:4012/sse
MCP_OLLAMA_URL=http://localhost:4013/sse
MCP_SYSTEM_URL=http://localhost:4014/sse
MCP_CRON_URL=http://localhost:4015/sse

# ==========================================
# Trieve RAG (SPEC-092)
# ==========================================
TRIEVE_URL=http://localhost:6435
# code: process.env.TRIEVE_API_KEY
TRIEVE_API_KEY=${TRIEVE_API_KEY}
TRIEVE_DEFAULT_DATASET_ID=

# ==========================================
# Mem0 / MCP Memory (SPEC-074)
# ==========================================
MEM0_COLLECTION=will
MEM0_EMBEDDING_MODEL=embedding-nomic
MEM0_LLM_MODEL=Gemma4-12b-it
MEM0_QDRANT_HOST=localhost
MEM0_QDRANT_PORT=6333
MEM0_LLM_PROVIDER=litellm
# code: process.env.MEM0_API_KEY
MEM0_API_KEY=${MEM0_API_KEY}

# ==========================================
# Cloudflare — Terraform + Tunnel + DNS
# ==========================================
#
# REGRA DE SEGURANÇA:
#   • Tokens em: /srv/ops/secrets/cloudflare-api-token.env (600, gitignored)
#   • Scripts: set -a; source cloudflare-env-sync.sh; set +a
#   • Terraform usa: TF_VAR_cloudflare_api_token
#
# TOKEN DEPLOY: lido de /srv/ops/secrets/cloudflare-api-token.env
# GLOBAL KEY: .env (só para cloudflare-token-create.sh)

# Global Key — code: process.env.CF_GLOBAL_KEY
# ⚠️ ATENÇÃO: Global key = acesso total. Só para criar tokens.
CF_GLOBAL_KEY=${CF_GLOBAL_KEY}
CF_EMAIL=zappro.ia@gmail.com

# Account & Zone IDs (público)
CLOUDFLARE_ACCOUNT_ID=1a41f45591a50585050f664fa015d01b
CLOUDFLARE_ZONE_ID=c0cf47bc153a6662f884d0f91e8da7c2

# Tunnel Info (público)
cloudflare_tunnel_name=will-zappro-homelab
cloudflare_tunnel_id=aee7a93d-c2e2-4c77-a395-71edc1821402
cloudflare_tunnel_cname=aee7a93d-c2e2-4c77-a395-71edc1821402.cfargotunnel.com

# ==========================================
# Observability (Grafana)
# ==========================================
GRAFANA_URL=https://grafana.zappro.site
# code: process.env.GRAFANA_ADMIN_PASSWORD
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
# code: process.env.GRAFANA_SERVICE_ACCOUNT_TOKEN
GRAFANA_SERVICE_ACCOUNT_TOKEN=${GRAFANA_SERVICE_ACCOUNT_TOKEN}

# ==========================================
# Git & Repositories (Gitea / GitHub)
# ==========================================
# code: process.env.GH_TOKEN
GH_TOKEN=${GH_TOKEN}
# code: process.env.GITHUB_TOKEN
GITHUB_TOKEN=${GITHUB_TOKEN}
GITEA_INSTANCE_URL=https://git.zappro.site
# code: process.env.GITEA_TOKEN
GITEA_TOKEN=${GITEA_TOKEN}
# code: process.env.GITEA_RUNNER_REGISTRATION_TOKEN
GITEA_RUNNER_REGISTRATION_TOKEN=${GITEA_RUNNER_REGISTRATION_TOKEN}

# ==========================================
# Google OAuth
# ==========================================
# code: process.env.GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=29245472860-6d5bvhphmk2pl3s1volthifqfhbg0iji.apps.googleusercontent.com
# code: process.env.GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
GOOGLE_REDIRECT_URI_LIST_WEB=https://list.zappro.site/auth/callback
GOOGLE_REDIRECT_URI_OBSIDIAN=https://obsidian.zappro.site/auth/callback
GOOGLE_REDIRECT_URI_TODO=https://todo.zappro.site/auth/callback

# ==========================================
# App Config (monorepo apps)
# ==========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
WEBAPP_URL=http://localhost:5173
VITE_API_URL=http://localhost:4002
API_SERVER_ENABLED=true
GATEWAY_ALLOW_ALL_USERS=false
# code: process.env.VOICE_TOOLS_OPENAI_KEY
VOICE_TOOLS_OPENAI_KEY=${VOICE_TOOLS_OPENAI_KEY}
MESSAGING_CWD=/data/workspace

# ==========================================
# Browser & Terminal Tools (Hermes)
# ==========================================
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# ==========================================
# Miscellaneous
# ==========================================
# code: process.env.SMTP_PASSWORD
SMTP_PASSWORD=${SMTP_PASSWORD}
# code: process.env.GF_SECURITY_ADMIN_PASSWORD
GF_SECURITY_ADMIN_PASSWORD=${GF_SECURITY_ADMIN_PASSWORD}
# code: process.env.WEBUI_SECRET_KEY
WEBUI_SECRET_KEY=${WEBUI_SECRET_KEY}

# ==========================================
# pgAdmin (Coolify)
# ==========================================
PGADMIN_DEFAULT_EMAIL=zappro.ia@gmail.com
# code: process.env.PGADMIN_DEFAULT_PASSWORD
PGADMIN_DEFAULT_PASSWORD=${PGADMIN_DEFAULT_PASSWORD}

