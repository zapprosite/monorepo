# Node Environment
VITE_NODE_ENV=development
NODE_ENV=development

# Backend Port — NÃO use 3000 (CapRover), 4000 (LiteLLM), 8000/8443 (Supabase), 5678 (n8n)
# Ver: /srv/ops/ai-governance/PORTS.md
PORT=4001

# Frontend Configuration
VITE_API_URL=http://localhost:4001

# URLs
WEBAPP_URL=http://localhost:5173

# Auth (Google OAuth2)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret

# Session (min 32 chars)
SESSION_SECRET=change-this-to-a-random-secret-minimum-32-chars

# Internal API (min 32 chars, optional)
INTERNAL_API_SECRET=change-this-to-a-random-secret-minimum-32-chars

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=connected_repo
