LITELLM_MODEL_LIST=nexus-auto,nexus-local-code,nexus-vision,nexus-embed,nexus-cloud-cheap,nexus-cloud-pro,nexus-cloud-ui,nexus-brain
LITELLM_EMBEDDING_MODEL=nexus-embed
LITELLM_EMBEDDING_DIM=768
LITELLM_DROP_params=true
DATABASE_URL="postgres://litellm:litellm_pass_2026@litellm-db:5432/litellm?sslmode=disable"

