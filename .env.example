# =============================================================================
# .env.example — AUTO-GENERATED by env-vault-sync.sh
# =============================================================================
# ==========================================
# Core & System
# ==========================================
NODE_ENV=development
DISPLAY=:1
GOGC=100
GOMEMLIMIT=512MiB
PORTEIRO_MODE=LOG_ONLY
API_BASE_URL=http://localhost:4001/trpc

# Cookie domain for cross-subdomain sessions (e.g. crm.zappro.site ↔ api.zappro.site)
COOKIE_DOMAIN=.zappro.site

# Generated secrets (2026-04-13)
SESSION_SECRET=${SESSION_SECRET}
INTERNAL_API_SECRET=${INTERNAL_API_SECRET}

# Feature Flags
FEAT_COMPUTER_USE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_VOICE=false
HOOKS_ENABLED=false
HOOKS_PATH=/hooks
BROWSER_EVALUATE_ENABLED=true

# ==========================================
# AI Models, LLMs & Gateways (SPEC-047)
# ==========================================
# Keys
OPEN_AI_KEY=${OPEN_AI_KEY}
GROQ_API_KEY=${GROQ_API_KEY}
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
OPENCODE_API_KEY=${OPENCODE_API_KEY}
GITHUB_TOKEN=${GITHUB_TOKEN}
GITEA_TOKEN=${GITEA_TOKEN}

HF_TOKEN=${HF_TOKEN}

OPENAI_BASE_URL=http://127.0.0.1:4018/v1


# Context7
CONTEXT7_ENABLED=true
CONTEXT7_API_KEY=${CONTEXT7_API_KEY}

# AI Gateway (Facade)
VOICE_GATEWAY_PORT=4002
AI_GATEWAY_FACADE_KEY=${AI_GATEWAY_FACADE_KEY}
PTBR_FILTER_MODEL=qwen2.5-coder:14b-q6k

# Llama.cpp Infrastructure (SPEC-061) - Replaces Ollama
LLAMA_CPP_MAIN_URL=http://host.docker.internal:8001/v1
LLAMA_CPP_VISION_URL=
LLAMA_CPP_EMBED_URL=http://172.17.0.1:8002/v1
LITELLM_DEFAULT_EMBEDDING_ENCODING_FORMAT=float
EMBED_USE_LITELLM=false
HVAC_EMBEDDING_URL=http://172.17.0.1:8002/v1

