# ==========================================
# MONOREPO CANONICAL ENV — HVAC CRM
# Template for all environment variables
# Copy to .env and fill in values
# ==========================================

# ==========================================
# NODE & RUNTIME
# ==========================================
NODE_ENV=development
DISPLAY=:1

# ==========================================
# API SERVER (apps/api) — Fastify + tRPC
# ==========================================
PORT=4000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=connected_repo_db
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=your_session_secret_min_32_chars_here
WEBAPP_URL=http://localhost:5173
VITE_API_URL=http://localhost:4000
INTERNAL_API_SECRET=your_internal_api_secret_min_32_chars
COOKIE_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# WEB APP (apps/web) — React 19 + Vite
# ==========================================
VITE_API_URL=http://localhost:4000
WEBAPP_URL=http://localhost:5173

# ==========================================
# AI GATEWAY (apps/ai-gateway)
# ==========================================
AI_GATEWAY_PORT=4002
AI_GATEWAY_FACADE_KEY=your_facade_key_here

# ==========================================
# LITELLM (Multi-Model Gateway)
# ==========================================
LITELLM_PORT=4000
LITELLM_HOST=0.0.0.0
LITELLM_URL=http://localhost:4000/v1
LITELLM_LOCAL_URL=http://localhost:4000/v1
LITELLM_PUBLIC_URL=https://llm.zappro.site/v1
LITELLM_UI_URL=http://localhost:4000/ui
LITELLM_MASTER_KEY=your_litellm_master_key
LITELLM_API_KEY=your_litellm_api_key
LITELLM_MODEL_LIST=embedding-nomic,Gemma4-12b-it,qwen2.5vl:3b
LITELLM_EMBEDDING_MODEL=embedding-nomic
LITELLM_EMBEDDING_DIM=768
LITELLM_DROP_params=True

# ==========================================
# OLLAMA (Local Models)
# ==========================================
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=Gemma4-12b-it
OLLAMA_VISION_MODEL=gemma4
PTBR_FILTER_MODEL=Gemma4-12b-it

# ==========================================
# HERMES AGENT
# ==========================================
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_API_KEY=your_hermes_api_key
HERMES_WEBHOOK_URL=https://hermes-agency.zappro.site/webhook
HERMES_VISION_MODEL=qwen2.5vl:7b
HERMES_VOICE=pm_santa
HERMES_ADMIN_USER_IDS=7220607041
HERMES_MAX_FILE_SIZE=20971520
HERMES_MAX_CONCURRENT=3
HERMES_LOCK_TTL_SEC=30
HERMES_RATE_WINDOW_MS=10000
HERMES_RATE_MAX_MSGS=5
HERMES_CLEANUP_INTERVAL_MS=60000
HERMES_CIRCUIT_BREAKER_THRESHOLD=5
HERMES_CIRCUIT_BREAKER_COOLDOWN_MS=30000
HERMES_MAX_TTS_SIZE_BYTES=52428800
HERMES_MAX_DOWNLOAD_BYTES=20971520

# ==========================================
# TTS BRIDGE (Edge TTS)
# ==========================================
TTS_BRIDGE_URL=http://localhost:8012
KOKORO_URL=http://localhost:8012

# ==========================================
# STT (Speech-to-Text)
# ==========================================
STT_PROXY_URL=http://localhost:8204
WHISPER_MEDIUM_PORT=8204
STT_DIRECT_URL=http://localhost:8204
DEEPGRAM_API_KEY=your_deepgram_api_key

# ==========================================
# QDRANT (Vector Database)
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=localhost:6334
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=will
QDRANT_VECTOR_DIM=768
QDRANT_DISTANCE=Cosine

# ==========================================
# POSTGRES & REDIS
# ==========================================
POSTGRES_PASSWORD=your_postgres_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://default:your_redis_password@localhost:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_RETRY_DELAY_MS=2000
REDIS_MAX_RETRIES=3

# ==========================================
# DATABASE (via litellm)
# ==========================================
DATABASE_URL=postgres://litellm:litellm_pass_2026@zappro-litellm-db:5432/litellm

# ==========================================
# MEM0 (Memory Layer)
# ==========================================
MEM0_COLLECTION=will
MEM0_EMBEDDING_MODEL=embedding-nomic
MEM0_LLM_MODEL=Gemma4-12b-it
MEM0_QDRANT_HOST=localhost
MEM0_QDRANT_PORT=6333
MEM0_LLM_PROVIDER=litellm
MEM0_API_KEY=your_mem0_api_key

# ==========================================
# TRIEVE
# ==========================================
TRIEVE_URL=http://localhost:6435
TRIEVE_API_KEY=your_trieve_api_key
TRIEVE_DEFAULT_DATASET_ID=

# ==========================================
# CLOUDFLARE (DNS + Tunnel)
# ==========================================
CF_GLOBAL_KEY=your_cloudflare_global_key
CF_EMAIL=zappro.ia@gmail.com
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
cloudflare_tunnel_name=will-zappro-homelab
cloudflare_tunnel_id=your_tunnel_id
cloudflare_tunnel_cname=your_tunnel_cname.cfargotunnel.com

# ==========================================
# COOLIFY (PaaS)
# ==========================================
COOLIFY_URL=https://coolify.zappro.site
COOLIFY_API_KEY=your_coolify_api_key
COOLIFY_APP_KEY=your_coolify_app_key
COOLIFY_ROOT_USER_PASSWORD=your_coolify_root_password
COOLIFY_DB_PASSWORD=your_coolify_db_password
COOLIFY_REDIS_PASSWORD=your_coolify_redis_password

# ==========================================
# GRAFANA (Monitoring)
# ==========================================
GRAFANA_URL=https://grafana.zappro.site
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password
GRAFANA_SERVICE_ACCOUNT_TOKEN=your_grafana_service_token

# ==========================================
# GITEA (Git Hosting)
# ==========================================
GITEA_INSTANCE_URL=https://git.zappro.site
GITEA_TOKEN=your_gitea_token
GITEA_RUNNER_REGISTRATION_TOKEN=your_gitea_runner_token

# ==========================================
# MCP CONNECTORS
# ==========================================
MCP_POSTGRES_HOST=localhost
MCP_POSTGRES_PORT=5432
MCP_COOLIFY_URL=http://localhost:4012/sse
MCP_OLLAMA_URL=http://localhost:4013/sse
MCP_SYSTEM_URL=http://localhost:4014/sse
MCP_CRON_URL=http://localhost:4015/sse

# ==========================================
# OPEN WEBUI
# ==========================================
WEBUI_SECRET_KEY=your_webui_secret_key
WEBUI_AUTH=openid
ENABLE_OAUTH_SIGNUP=true
OPENWEBUI_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
OPENWEBUI_GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://chat.zappro.site/oauth/google/callback
WEBUI_URL=https://chat.zappro.site
WEBUI_SESSION_COOKIE_SECURE=true
OPENID_PROVIDER_URL=https://accounts.google.com/.well-known/openid-configuration
OPENAI_API_BASE_URL=http://localhost:4017/v1
OPENAI_API_KEY=your_openai_api_key
DEFAULT_MODELS=zappro-clima-tutor
DEFAULT_PINNED_MODELS=zappro-clima-tutor
ENABLE_OLLAMA_API=false
ENABLE_LOGIN_FORM=true
WEBUI_ADMIN_EMAIL=admin@zappro.local
WEBUI_ADMIN_PASSWORD=your_webui_admin_password
WEBUI_ADMIN_NAME=Admin

# ==========================================
# SMARTCOLLECT (n8n-like)
# ==========================================
SMARTCOLLECT_URL=http://localhost:5678
SMARTCOLLECT_API_KEY=your_smartcollect_api_key

# ==========================================
# WEB SEARCH (Tavily)
# ==========================================
TAVILY_API_KEY=your_tavily_api_key
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_FALLBACKS=ddg,google_news
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# ==========================================
# TELEGRAM BOTS
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=7220607041
TELEGRAM_ALLOWED_USERS=7220607041
ATHLOS_BOT_TOKEN=your_athlos_bot_token
HOMELAB_LOGS_BOT_TOKEN=your_homelab_logs_bot_token

# ==========================================
# AI PROVIDER KEYS
# ==========================================
OPEN_AI_KEY=your_openai_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
OPENCODE_API_KEY=your_opencode_api_key
HF_TOKEN=your_huggingface_token
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_API_BASE=https://api.minimax.io
HERMES_MINIMAX_BASE=https://api.minimax.io/anthropic/v1
CONTEXT7_ENABLED=true
CONTEXT7_API_KEY=your_context7_api_key

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_PASSWORD=your_smtp_password
GF_SECURITY_ADMIN_PASSWORD=your_gf_admin_password

# ==========================================
# BROWSER / COMPUTER USE
# ==========================================
FEAT_COMPUTER_USE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_VOICE=false
HOOKS_ENABLED=false
HOOKS_PATH=/hooks
BROWSER_EVALUATE_ENABLED=true
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# ==========================================
# TERMINAL / DEV CONTAINER
# ==========================================
MESSAGING_CWD=/data/workspace
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
VOICE_TOOLS_OPENAI_KEY=your_voice_tools_openai_key

# ==========================================
# PERFORMANCE
# ==========================================
GOGC=100
GOMEMLIMIT=512MiB
PORTEIRO_MODE=LOG_ONLY

# ==========================================
# PGADMIN
# ==========================================
PGADMIN_DEFAULT_EMAIL=zappro.ia@gmail.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# ==========================================
# TASK MODEL
# ==========================================
TASK_MODEL_EXTERNAL=zappro-clima-tutor
