# ==========================================
# Hermes Agent & Voice Pipeline
# ==========================================
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_API_KEY=${HERMES_API_KEY}
HERMES_WEBHOOK_URL=https://hermes-agency.zappro.site/webhook
HERMES_VISION_MODEL=qwen2.5vl:3b
HERMES_VOICE=pm_santa

# Voice Pipeline URLs
TTS_BRIDGE_URL=http://localhost:8012
KOKORO_URL=http://localhost:8012
DEEPGRAM_API_KEY=${DEEPGRAM_API_KEY}

# Telegram Bots (CEO_REFRIMIX @CEO_REFRIMIX_bot é o agent lider)
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
TELEGRAM_CHAT_ID=7220607041
TELEGRAM_ALLOWED_USERS=7220607041
ATHLOS_BOT_TOKEN=${ATHLOS_BOT_TOKEN}
HOMELAB_LOGS_BOT_TOKEN=${HOMELAB_LOGS_BOT_TOKEN}

# Hermes Agency Datacenter Hardening (SPEC-059)
HERMES_ADMIN_USER_IDS=7220607041
HERMES_MAX_FILE_SIZE="20971520  # 20MB in bytes"
HERMES_MAX_CONCURRENT="3  # max concurrent uploads per user"
HERMES_LOCK_TTL_SEC="30  # distributed lock TTL in seconds"
HERMES_RATE_WINDOW_MS="10000  # rate limit window in milliseconds"
HERMES_RATE_MAX_MSGS="5  # max messages per rate limit window"
HERMES_CLEANUP_INTERVAL_MS="60000  # memory cleanup interval in milliseconds"
HERMES_CIRCUIT_BREAKER_THRESHOLD="5  # failures before circuit breaker opens"
HERMES_CIRCUIT_BREAKER_COOLDOWN_MS="30000  # circuit breaker cooldown in milliseconds"
HERMES_MAX_TTS_SIZE_BYTES="52428800  # 50MB max TTS response size"
HERMES_MAX_DOWNLOAD_BYTES="20971520  # 20MB max Telegram file download (streaming limit)"

# ==========================================
# Databases & Storage
# ==========================================
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DB_HOST=litellm-db
DB_PORT=5432
DB_NAME=connected_repo_db
DB_USER=litellm
DB_PASSWORD=${DB_PASSWORD}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_URL="redis://:Fifine156458*@localhost:6379"
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_RETRY_DELAY_MS=2000
REDIS_MAX_RETRIES=3

