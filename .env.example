# =============================================================================
# homelab-monorepo — Environment Variables Template
# =============================================================================
# THIS FILE IS THE CANONICAL SOURCE FOR ALL ENV VAR DOCUMENTATION.
# Values are placeholders only. Never commit real secrets here.
#
# Rule: Code reads from .env, never hardcodes secrets.
# See: docs/GUIDES/env-management.md
# =============================================================================

# =============================================================================
# NODE / VITE ENVIRONMENT
# =============================================================================
VITE_NODE_ENV=development
NODE_ENV=development

# =============================================================================
# PORTS (reserved ranges — see /srv/ops/ai-governance/PORTS.md)
# DO NOT use: 3000 (OpenWebUI), 4000 (LiteLLM), 4001 (OpenClaw Bot),
#             8000/8443 (Supabase), 5173 (Vite dev server)
# =============================================================================
PORT=4001

# =============================================================================
# FRONTEND / URLS
# =============================================================================
VITE_API_URL=http://localhost:4001
WEBAPP_URL=http://localhost:5173

# =============================================================================
# AUTHENTICATION — Google OAuth2
# =============================================================================
# OAuth 2.0 client credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-secret

# =============================================================================
# SESSION & INTERNAL API
# Minimum 32 characters. Generate with: openssl rand -base64 32
# =============================================================================
SESSION_SECRET=change-this-to-a-random-secret-minimum-32-chars
INTERNAL_API_SECRET=change-this-to-a-random-secret-minimum-32-chars

# =============================================================================
# DATABASE — PostgreSQL (Orchid ORM)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=connected_repo

# Additional database passwords (Coolify, n8n, Infisical)
# COOLIFY_DB_PASSWORD=
# COOLIFY_REDIS_PASSWORD=
# INFISICAL_DB_PASSWORD=
# INFISICAL_REDIS_PASSWORD=
# N8N_DB_PASSWORD=
# POSTGRES_PASSWORD=

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# =============================================================================
# LLM PROVIDERS — API Keys
# =============================================================================
# MiniMax (Active - Optional fallback for Hermes voice pipeline, Ollama is primary per SPEC-053)
MINIMAX_API_KEY=replace-with-openssl-rand-hex-32
token_minimax-m2.7_plano=replace-with-openssl-rand-hex-32
# MINIMAX_API_KEY=sk-cp-... # OLD - ROTATED 2026-04-16

# OpenAI (GPT models)
OPEN_AI_KEY=sk-proj-...

# OpenRouter (aggregator)
OPENROUTER_API_KEY=sk-or-v1-...

# OpenCode (code generation)
OPENCODE_API_KEY=sk-nQ5r-...

# Context7 (code documentation — MCP)
CONTEXT7_API_KEY=ctx7sk-...
CONTEXT7_ENABLED=true

# =============================================================================
# LITEllM — Local LLM Proxy
# =============================================================================
LITELLM_URL=https://llm.zappro.site/v1
LITELLM_LOCAL_URL=http://localhost:4000/v1
LITELLM_UI_URL=http://localhost:4000/ui
LITELLM_MASTER_KEY=sk-master-...

# =============================================================================
# OLLAMA — Local Models
# =============================================================================
OLLAMA_MODEL=Gemma4-12b-it

# =============================================================================
# OPENCLAW — Voice Bot (SPEC-009 audio stack)
# DO NOT change STT/TTS/LLM routing — see openclaw-audio-governance.md
# OPENCLAW_USER=your-openclaw-user  # DEPRECATED - OpenClaw legacy
# OPENCLAW_PASSWORD=your-openclaw-password  # DEPRECATED - OpenClaw legacy
DEEPGRAM_API_KEY=replace-with-openssl-rand-hex-32
# OPENCLAW_DEEPGRAM_API_KEY=your-deepgram-api-key  # DEPRECATED - OpenClaw legacy
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token  # DEPRECATED - OpenClaw legacy
# OPENCLAW_GEMINI_API_KEY=your-gemini-api-key  # DEPRECATED - OpenClaw legacy

# =============================================================================
# PORTEIRO — Access Control
# =============================================================================
PORTEIRO_MODE=LOG_ONLY

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEAT_COMPUTER_USE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_VOICE=false
FEAT_...

# =============================================================================
# COOLIFY — Self-hosted PaaS
# =============================================================================
COOLIFY_URL=https://coolify.zappro.site
COOLIFY_API_KEY=your-coolify-api-key
COOLIFY_APP_KEY=base64:...
COOLIFY_DB_PASSWORD=your-coolify-db-password
COOLIFY_REDIS_PASSWORD=your-coolify-redis-password
COOLIFY_ROOT_USER_PASSWORD=your-coolify-root-password

# =============================================================================
# GITEA — Self-hosted Git
# =============================================================================
GITEA_INSTANCE_URL=https://git.zappro.site
GITEA_TOKEN=your-gitea-token
GITEA_RUNNER_REGISTRATION_TOKEN=your-runner-token
GROQ_API_KEY=replace-with-openssl-rand-hex-32

# =============================================================================
# GRAFANA — Metrics & Dashboards
# =============================================================================
GRAFANA_URL=https://grafana.zappro.site
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_...

# =============================================================================
# N8N — Workflow Automation
# =============================================================================
N8N_URL=https://n8n.zappro.site
N8N_WEBHOOK_URL=https://n8n.zappro.site/webhook
N8N_API_KEY=your-n8n-api-key
N8N_RUNNERS_AUTH_TOKEN=your-n8n-runners-auth-token

# =============================================================================
# QDRANT — Vector Database
# =============================================================================
QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# DISPLAY — X11 / GUI (headless servers)
# =============================================================================
DISPLAY=:1

# =============================================================================
# GO RUNTIME — Memory limits
# =============================================================================
GOGC=100
GOMEMLIMIT=512MiB

# =============================================================================
# HOOKS — Pre-commit / CI hooks
# =============================================================================
HOOKS_ENABLED=false
HOOKS_PATH=/hooks

# =============================================================================
# TELEGRAM — Bot notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# =============================================================================
# SMTP — Email (for notifications)
# =============================================================================
SMTP_PASSWORD=your-smtp-password

# =============================================================================
# WEBUI — OpenWebUI
# =============================================================================
WEBUI_SECRET_KEY=your-webui-secret-key

# =============================================================================
# CLOUDFLARE — Tunnel & API
# =============================================================================
cloudflare_tunnel_id=your-tunnel-id
cloudflare_tunnel_name=will-zappro-homelab
cloudflare_tunnel_cNAME=your-tunnel-id.cfargotunnel.com
cloudflare_tunnel_secret=your-tunnel-secret
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# =============================================================================
# INFISICAL — Secrets Management
# Get from: Infisical vault (ask Master Will if missing)
# =============================================================================
INFISICAL_TOKEN=st.your-infisical-token

# OAuth Client (for obsidian-web, list-web)
# INFISICAL_CLIENT_ID=<OBTER DO VAULT>
# INFISICAL_CLIENT_SECRET=<OBTER DO VAULT>

# =============================================================================
# GITHUB — CI/CD
# =============================================================================
GH_TOKEN=ghp_your-github-token

# =============================================================================
# OPTIONAL — Axiom (log aggregation)
# =============================================================================
# AXIOM_DATASET=your-dataset
# AXIOM_TOKEN=your-axiom-token

# =============================================================================
# SPEC-047 — AI Gateway (OpenAI-compatible facade, PT-BR Llama filter)
# =============================================================================
OLLAMA_URL=http://localhost:11434
# STT_PROXY_URL=http://localhost:8204  # DEPRECATED - OpenClaw legacy
PTBR_FILTER_MODEL=llama3-portuguese-tomcat-8b-instruct-q8
AI_GATEWAY_PORT=4002
# Generate with: openssl rand -hex 32 — sync to Infisical
AI_GATEWAY_FACADE_KEY=replace-with-openssl-rand-hex-32

HERMES_API_KEY=replace-me
STT_DIRECT_URL=http://localhost:8204
HF_TOKEN=replace-with-your-huggingface-token
