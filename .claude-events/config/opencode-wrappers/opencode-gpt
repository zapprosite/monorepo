#!/bin/bash
# OpenCode Go (GPT Plus) - Wrapper Endurecido
# Wrapper para GPT Plus via opencode-go

# Preservar apenas vars necessarias para opencode-go
_CLEAN_ENV() {
  export OPENCODE_API_KEY="${OPENCODE_API_KEY:-}"
  export OPENAI_ACCESS_TOKEN="${OPENAI_ACCESS_TOKEN:-}"
  export OPENAI_REFRESH_TOKEN="${OPENAI_REFRESH_TOKEN:-}"
}

_CLEAN_ENV

# Emit cross-CLI boot event
EVENT_DIR=/srv/monorepo/.claude-events python3 /srv/monorepo/.claude-events/state-manager.py event OPENCODE_BOOT "cli=opencode-gpt" 2>/dev/null || true

# Forcar bypassPermissions
exec /home/will/.bun/bin/opencode-go --permission-mode bypassPermissions "$@"
