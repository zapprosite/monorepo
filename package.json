{
	"name": "connected-repo",
	"version": "1.0.0",
	"description": "Starter Monorepo using Turbo of Nodejs + Fastify + OrchidORM + tRPC + Reactjs with opentelemetry setup",
	"repository": "git@github.com:zapprosite/homelab-monorepo.git",
	"author": "will <will@zapprosite.com>",
	"license": "AGPL-3.0-only",
	"private": true,
	"scripts": {
		"env:sync": "node scripts/sync-env.js",
		"build": "pnpm env:sync && turbo run build",
		"clean": "turbo run clean && rm -rf node_modules && rm -rf .pnpm-store",
		"db:migrate": "turbo db:migrate --",
		"db:seed": "turbo db:seed --",
		"dev": "pnpm env:sync && turbo run dev",
		"lint": "turbo run lint",
		"format": "biome format . --write",
		"check-types": "turbo run check-types",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"syncpack": "syncpack format"
	},
	"dependencies": {
		"@trpc/server": "^11.7.0",
		"ulid": "^3.0.1",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@playwright/test": "^1.59.1",
		"concurrently": "^9.2.1",
		"tsc": "^2.0.4",
		"tsc-alias": "^1.8.16",
		"turbo": "2.9.6",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@9.0.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
