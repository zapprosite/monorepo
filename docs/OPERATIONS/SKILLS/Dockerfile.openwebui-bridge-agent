FROM python:3.11-slim

WORKDIR /app

# Install Node.js (for future extensibility)
# NOTE: @infisical/cli removed per SPEC-029/ADR-001 — .env is canonical source
RUN apt-get update -qq && apt-get install -y -qq curl gnupg > /dev/null 2>&1 \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - > /dev/null 2>&1 \
    && apt-get install -y -qq nodejs > /dev/null 2>&1 \
    && apt-get clean > /dev/null 2>&1 \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Copy application files
COPY openwebui_bridge_agent.py /app/

# Required env vars (must be set at runtime via .env — canonical source)
ENV PORT=3456
ENV SECRET_KEYS=OPENCLAW_GATEWAY_TOKEN,OPENCLAW_BASE_URL
ENV OPENCLAW_BASE_URL=http://10.0.19.4:8080

EXPOSE 3456

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:3456/health')" || exit 1

CMD ["python3", "openwebui_bridge_agent.py"]
