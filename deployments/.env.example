# Environment template for hvacr-swarm deployments
# Copy to .env and fill in values

# Redis
REDIS_ADDR=redis:6379

# Qdrant Vector Database
QDRANT_ADDR=qdrant:6333

# Google Gemini
GEMINI_API_KEY=

# Stripe
STRIPE_WEBHOOK_SECRET=whsec_

# WhatsApp Business API
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Tailscale (for homelab access)
TAILSCALE_AUTHKEY=

# Swarm HTTP port (default: :8080)
SWARM_HTTP_PORT=:8080