{
	"pipeline_id": "PIPE-ENTERPRISE-001",
	"name": "Nexus Enterprise Pipeline — Monorepo Full Stack",
	"version": "1.0.0",
	"created": "2026-05-03",
	"status": "in_progress",
	"spec_ref": "SPEC-ENTERPRISE",
	"adr_ref": "ADR-030",
	"description": "Enterprise-grade pipeline for the full monorepo: 11 apps, 8 packages, 26+ API modules, HVAC CRM, AI Gateway, and infrastructure.",

	"phases": [
		{
			"phase_id": "PE1",
			"name": "Code Quality & Type Safety",
			"order": 1,
			"status": "pending",
			"sensors": ["tsc", "biome", "secret-scan"],
			"tasks": [
				{
					"task_id": "PE1-T1",
					"name": "TypeScript strict mode validation",
					"type": "quality",
					"command": "pnpm tsc --noEmit",
					"sensors": ["tsc"]
				},
				{
					"task_id": "PE1-T2",
					"name": "Biome lint + format",
					"type": "quality",
					"command": "biome check . --write",
					"sensors": ["biome"]
				},
				{
					"task_id": "PE1-T3",
					"name": "Secrets scan pre-commit",
					"type": "security",
					"command": "grep -rE 'sk-[a-zA-Z0-9]{20,}|ghp_|cfut_|glpat-' --include='*.ts' --include='*.tsx' --include='*.py' apps/ packages/",
					"sensors": ["secret-scan"]
				},
				{
					"task_id": "PE1-T4",
					"name": "Unused imports/vars cleanup",
					"type": "refactor",
					"verify": "pnpm tsc --noEmit passes"
				}
			]
		},
		{
			"phase_id": "PE2",
			"name": "Database & Migrations",
			"order": 2,
			"status": "pending",
			"depends_on": ["PE1"],
			"tasks": [
				{
					"task_id": "PE2-T1",
					"name": "Validate database schema (equipment + PMOC fields)",
					"type": "db",
					"tables": [
						"equipment (sequenceNumber)",
						"maintenance_plans (planType, creaResponsavel, laudoTecnico, numeroEquipamentos, potenciaTotal, cargaTermica, vazioSanitario)",
						"clients",
						"contracts",
						"service_orders"
					],
					"verify": "pnpm db:migrate --dry-run"
				},
				{
					"task_id": "PE2-T2",
					"name": "Seed development data",
					"type": "db",
					"command": "cd apps/api && pnpm db:seed",
					"depends_on": ["PE2-T1"]
				}
			]
		},
		{
			"phase_id": "PE3",
			"name": "API Modules — Core CRUD",
			"order": 3,
			"status": "pending",
			"depends_on": ["PE2"],
			"modules": [
				{ "name": "equipment", "path": "apps/api/src/modules/equipment", "status": "done" },
				{ "name": "maintenance", "path": "apps/api/src/modules/maintenance", "status": "done" },
				{ "name": "clients", "path": "apps/api/src/modules/clients", "status": "done" },
				{ "name": "contracts", "path": "apps/api/src/modules/contracts", "status": "done" },
				{ "name": "leads", "path": "apps/api/src/modules/leads", "status": "done" },
				{
					"name": "service-orders",
					"path": "apps/api/src/modules/service-orders",
					"status": "pending"
				},
				{
					"name": "subscriptions",
					"path": "apps/api/src/modules/subscriptions",
					"status": "pending"
				},
				{ "name": "schedule", "path": "apps/api/src/modules/schedule", "status": "pending" },
				{ "name": "reminders", "path": "apps/api/src/modules/reminders", "status": "pending" }
			],
			"tasks": [
				{
					"task_id": "PE3-T1",
					"name": "tRPC router validation — all done modules",
					"type": "code",
					"verify": "pnpm build 2>&1 | grep -c 'error' == 0"
				},
				{
					"task_id": "PE3-T2",
					"name": "Service Orders module — remaining CRUD",
					"type": "feature",
					"module": "service-orders",
					"files": [
						"apps/api/src/modules/service-orders/service_order.table.ts",
						"apps/api/src/modules/service-orders/service_orders.trpc.ts"
					]
				},
				{
					"task_id": "PE3-T3",
					"name": "Subscriptions module — remaining CRUD",
					"type": "feature",
					"module": "subscriptions"
				},
				{
					"task_id": "PE3-T4",
					"name": "Schedule module — remaining CRUD",
					"type": "feature",
					"module": "schedule"
				},
				{
					"task_id": "PE3-T5",
					"name": "Reminders module — remaining CRUD",
					"type": "feature",
					"module": "reminders"
				}
			]
		},
		{
			"phase_id": "PE4",
			"name": "AI Gateway + LiteLLM Proxy",
			"order": 4,
			"status": "pending",
			"depends_on": ["PE3"],
			"modules": [
				{ "name": "ai-gateway", "path": "apps/ai-gateway", "port": 4002 },
				{ "name": "orchestrator", "path": "apps/orchestrator" }
			],
			"tasks": [
				{
					"task_id": "PE4-T1",
					"name": "AI Gateway health check",
					"type": "deploy",
					"verify": "curl -sf http://localhost:4002/health | jq .status"
				},
				{
					"task_id": "PE4-T2",
					"name": "LiteLLM proxy validation",
					"type": "infra",
					"verify": "curl -sf http://localhost:4000/v1/models | jq ."
				}
			]
		},
		{
			"phase_id": "PE5",
			"name": "Infrastructure — Terraform + Cloudflare",
			"order": 5,
			"status": "pending",
			"depends_on": ["PE4"],
			"tasks": [
				{
					"task_id": "PE5-T1",
					"name": "Terraform plan — RG subdomain sync",
					"type": "infra",
					"command": "cd /srv/ops/terraform/cloudflare && terraform plan",
					"verify": "terraform plan | grep 'No changes.'"
				},
				{
					"task_id": "PE5-T2",
					"name": "Sync equipment RG records to DNS",
					"type": "infra",
					"command": "bash /srv/ops/scripts/sync-equipment-rg.sh",
					"verify": "terraform apply (dry-run)"
				},
				{
					"task_id": "PE5-T3",
					"name": "Cloudflare tunnel health",
					"type": "infra",
					"verify": "journalctl -u cloudflared -n 5 | grep -E 'healthy|error'"
				}
			]
		},
		{
			"phase_id": "PE6",
			"name": "Frontend — Web App",
			"order": 6,
			"status": "pending",
			"depends_on": ["PE3"],
			"apps": [
				{ "name": "web", "path": "apps/web", "port": 5173 },
				{ "name": "monitoring", "path": "apps/monitoring" },
				{ "name": "list-web", "path": "apps/list-web" }
			],
			"tasks": [
				{
					"task_id": "PE6-T1",
					"name": "Build web app",
					"type": "ui",
					"command": "cd apps/web && pnpm build",
					"verify": "ls dist/*.js | wc -l > 0"
				},
				{
					"task_id": "PE6-T2",
					"name": "Dark mode + acid green theme validation",
					"type": "ui",
					"verify": "grep -r '#39FF14' packages/ui/src/theme/ || grep -r '39FF14' apps/web/src/"
				},
				{
					"task_id": "PE6-T3",
					"name": "Equipment RG page smoke test",
					"type": "test",
					"verify": "playwright test tests/smoke/"
				}
			]
		},
		{
			"phase_id": "PE7",
			"name": "Smoke Tests + Health Checks",
			"order": 7,
			"status": "pending",
			"depends_on": ["PE4", "PE5", "PE6"],
			"sensors": ["api-health", "db-health", "trpc-health", "smoke-tests"],
			"tasks": [
				{
					"task_id": "PE7-T1",
					"name": "API health endpoint",
					"type": "test",
					"verify": "curl -sf http://localhost:4000/health | jq .status == 'ok'"
				},
				{
					"task_id": "PE7-T2",
					"name": "tRPC equipment.listEquipment smoke",
					"type": "test",
					"verify": "curl -s http://localhost:4000/trpc/equipment.listEquipment?input={} | jq .result.data.json.length >= 0"
				},
				{
					"task_id": "PE7-T3",
					"name": "PostgreSQL connectivity",
					"type": "db",
					"verify": "pg_isready -h $DB_HOST -p $DB_PORT"
				},
				{
					"task_id": "PE7-T4",
					"name": "Full smoke test suite",
					"type": "test",
					"command": "pnpm test --filter=./apps/api",
					"sensors": ["smoke-tests"]
				}
			]
		},
		{
			"phase_id": "PE8",
			"name": "Deploy & Ship",
			"order": 8,
			"status": "pending",
			"depends_on": ["PE7"],
			"tasks": [
				{
					"task_id": "PE8-T1",
					"name": "Git commit — if dirty",
					"type": "deploy",
					"verify": "git status --short | wc -l > 0 ? commit : skip"
				},
				{
					"task_id": "PE8-T2",
					"name": "GitHub PR creation",
					"type": "deploy",
					"verify": "gh pr create --fill"
				},
				{
					"task_id": "PE8-T3",
					"name": "Nexus deploy validation",
					"type": "deploy",
					"verify": "nexus-investigate.sh all 3"
				}
			]
		}
	],

	"inventory": {
		"apps": {
			"count": 11,
			"list": [
				"ai-gateway",
				"api",
				"archived",
				"hvac-manual-downloader",
				"list-web",
				"monitoring",
				"obsidian-web",
				"orchestrator",
				"painel-organism",
				"perplexity-agent",
				"web"
			]
		},
		"packages": {
			"count": 8,
			"list": ["config", "db", "email", "env", "trpc", "ui", "zod-schemas"]
		},
		"api_modules": {
			"count": 26,
			"done": [
				"equipment",
				"maintenance",
				"clients",
				"contracts",
				"leads",
				"users",
				"teams",
				"auth",
				"dashboard",
				"webhooks",
				"mcp-connectors",
				"api-gateway",
				"content-engine",
				"editorial",
				"email",
				"haystack",
				"journal-entries",
				"kanban",
				"logs",
				"loyalty",
				"prompts",
				"schedule",
				"service-orders",
				"subscriptions",
				"trieve"
			],
			"pending": []
		},
		"database_tables": {
			"equipment": { "sequenceNumber": "done", "PMOC": "done" },
			"maintenance_plans": { "planType": "done", "PMOC_fields": "done" },
			"clients": { "core": "done" },
			"units": { "core": "done" },
			"contracts": { "core": "done" },
			"service_orders": { "core": "pending" },
			"subscriptions": { "core": "pending" }
		}
	},

	"vars": {
		"accent_color": "#39FF14",
		"rg_domain": "zappro.site",
		"theme": "dark",
		"api_port": 4000,
		"ai_gateway_port": 4002,
		"web_port": 5173,
		"db_name": "connected_repo_db",
		"db_host": "zappro-litellm-db",
		"stack": "Fastify + tRPC + Orchid ORM + PostgreSQL",
		"frontend": "React 19 + Vite + MUI + Tailwind",
		"llm_primary": "minimax/MiniMax-M2.7",
		"llm_fallback": "ollama/llama3-portuguese-tomcat-8b-instruct-q8",
		"auth": "OAuth2 Google + Dev Bypass via X-Dev-User"
	},

	"commands": {
		"type_check": "pnpm tsc --noEmit",
		"lint": "biome check . --write",
		"build": "pnpm build",
		"db_migrate": "cd apps/api && pnpm db:migrate",
		"db_seed": "cd apps/api && pnpm db:seed",
		"dev": "cd apps/api && pnpm dev",
		"health": "curl -sf http://localhost:4000/health",
		"tf_plan": "cd /srv/ops/terraform/cloudflare && terraform plan",
		"tf_apply": "cd /srv/ops/terraform/cloudflare && terraform apply",
		"smoke": "pnpm test --filter=./apps/api",
		"nexus_status": "bash /srv/ops/scripts/nexus-investigate.sh all 3"
	},

	"gates": {
		"PE1_to_PE2": { "requires": ["PE1-T1", "PE1-T2"], " блокирующий": true },
		"PE2_to_PE3": { "requires": ["PE2-T1"], " блокирующий": true },
		"PE3_to_PE4": { "requires": ["PE3-T1"], " блокирующий": false },
		"PE7_to_PE8": { "requires": ["PE7-T1", "PE7-T2", "PE7-T3", "PE7-T4"], " блокирующий": true }
	}
}
